<!DOCTYPE html>
<html lang="ro">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FIFA World Cup 2026</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:Arial, sans-serif;
    background:#f4f4f4;
    transition:0.3s;
}

/* NAVBAR */

.navbar{
    display:flex;
    justify-content:space-between;
    align-items:center;
    border-bottom:2px solid black;
    padding:15px;
    background:white;
}

.nav-left span{
    margin-right:20px;
    cursor:pointer;
    transition:0.3s;
}

.nav-left span:hover{
    color:red;
}

.nav-right{
    padding:5px;
}

/* BUTON TEMĂ */

#themeBtn{
    padding:8px 12px;
    border:none;
    cursor:pointer;
    background:black;
    color:white;
    border-radius:5px;
    transition:0.3s;
}

#themeBtn:hover{
    transform:scale(1.05);
}

/* MAIN */

.main{
    position:relative;
    min-height:100vh;
}

.vertical-text{
    position:absolute;
    left:10px;
    top:120px;
    writing-mode:vertical-rl;
    transform:rotate(180deg);
    font-size:28px;
    font-weight:bold;
}

/* HERO */

.hero{
    position:absolute;
    top:100px;
    left:650px;
    text-align:center;
}

.hero h1{
    font-size:42px;
    margin-bottom:10px;
}

.hero p{
    font-size:20px;
}

.hero button{
    margin-top:15px;
    padding:10px 20px;
    border:none;
    background:darkred;
    color:white;
    cursor:pointer;
    transition:0.3s;
}

.hero button:hover{
    background:red;
    transform:scale(1.1);
}

/* FLAGS */

.flag{
    position:absolute;
    width:180px;
    height:100px;
    border:1px solid black;
    transition:0.3s;
}

.flag:hover{
    transform:scale(1.1);
}

.usa{
    top:100px;
    left:150px;
}

.canada{
    top:100px;
    left:400px;
}

.mexico{
    top:250px;
    left:150px;
    width:140px;
    height:80px;
}

/* TABLE */

.table-container{
    position:absolute;
    top:400px;
    left:150px;
    border:2px solid black;
    padding:10px;
    background:white;
}

table{
    border-collapse:collapse;
}

td{
    width:18px;
    height:18px;
    border:1px solid black;
}

/* CARDS */

.cards{
    display:flex;
    justify-content:center;
    gap:20px;
    margin-top:750px;
    padding-bottom:50px;
}

.card{
    width:250px;
    background:white;
    border:2px solid black;
    padding:20px;
    text-align:center;
    transition:0.3s;
}

.card:hover{
    transform:translateY(-10px);
    background:#ececec;
}

.card h3{
    margin-bottom:10px;
}

/* FOOTER */

footer{
    text-align:center;
    background:#111;
    color:white;
    padding:20px;
}

/* DARK MODE */

.dark-mode{
    background:#121212;
    color:white;
}

.dark-mode .navbar{
    background:#1e1e1e;
    border-color:white;
}

.dark-mode .table-container{
    background:#1e1e1e;
    border-color:white;
}

.dark-mode td{
    border-color:white;
}

.dark-mode .card{
    background:#1e1e1e;
    border-color:white;
    color:white;
}

.dark-mode .card:hover{
    background:#2b2b2b;
}

.dark-mode footer{
    background:black;
}

.dark-mode #themeBtn{
    background:white;
    color:black;
}

/* ========================= */
/* TABLETĂ */
/* ========================= */

@media screen and (max-width:1024px){

    .hero{
        left:350px;
    }

    .cards{
        flex-wrap:wrap;
    }

    .flag{
        width:140px;
        height:80px;
    }
}

/* ========================= */
/* TELEFON */
/* ========================= */

@media screen and (max-width:768px){

    .navbar{
        flex-direction:column;
        gap:10px;
    }

    .nav-left{
        text-align:center;
    }

    .vertical-text{
        display:none;
    }

    .main{
        display:flex;
        flex-direction:column;
        align-items:center;
        min-height:auto;
    }

    .hero{
        position:static;
        margin-top:30px;
        margin-bottom:30px;
    }

    .usa,
    .canada,
    .mexico{
        position:static;
        margin:10px auto;
    }

    .table-container{
        position:static;
        margin:20px auto;
    }

    .cards{
        flex-direction:column;
        align-items:center;
        margin-top:30px;
    }
}

/* ========================= */
/* ECRANE MICI */
/* ========================= */

@media screen and (max-width:480px){

    .hero h1{
        font-size:28px;
    }

    .hero p{
        font-size:16px;
    }

    .flag{
        width:120px;
        height:70px;
    }

    .card{
        width:90%;
    }

    .nav-left span{
        display:block;
        margin:8px 0;
    }
}

</style>
</head>

<body>

<!-- NAVBAR -->

<div class="navbar">

    <div class="nav-left">
        <span>Home</span>
        <span>News</span>
        <span>Ranking</span>
        <span>Matches</span>
        <span>Tickets</span>
        <span>WC 2026 Winner</span>
    </div>

    <div class="nav-right">
        <button id="themeBtn">🌙 Dark Mode</button>
    </div>

</div>

<!-- MAIN -->

<div class="main">

    <div class="vertical-text">
        FIFA WORLD CUP
    </div>

    <!-- HERO -->

    <div class="hero">
        <h1>FIFA World Cup 2026</h1>
        <p>Hosted by USA, Canada & Mexico</p>
        <button>Buy Tickets</button>
    </div>

    <!-- FLAGS -->

    <img class="flag usa"
         src="https://flagcdn.com/w320/us.png"
         alt="USA">

    <img class="flag canada"
         src="https://flagcdn.com/w320/ca.png"
         alt="Canada">

    <img class="flag mexico"
         src="https://flagcdn.com/w320/mx.png"
         alt="Mexico">

    <!-- TABLE -->

    <div class="table-container">
        <table id="grid"></table>
    </div>

</div>

<!-- CARDS -->

<div class="cards">

    <div class="card">
        <h3>USA</h3>
        <p>
            United States will host most of the matches
            during FIFA World Cup 2026.
        </p>
    </div>

    <div class="card">
        <h3>Canada</h3>
        <p>
            Toronto and Vancouver are the selected
            host cities.
        </p>
    </div>

    <div class="card">
        <h3>Mexico</h3>
        <p>
            Mexico becomes the first nation to host
            three FIFA World Cups.
        </p>
    </div>

</div>

<!-- FOOTER -->

<footer>
    <p>© 2026 FIFA World Cup Project</p>
</footer>

<script>

// GENERARE TABEL

let table = document.getElementById("grid");

for(let i = 0; i < 15; i++){

    let row = table.insertRow();

    for(let j = 0; j < 30; j++){

        row.insertCell();

    }
}

// DARK MODE / LIGHT MODE

const themeBtn = document.getElementById("themeBtn");

themeBtn.addEventListener("click", function(){

    document.body.classList.toggle("dark-mode");

    if(document.body.classList.contains("dark-mode")){
        themeBtn.innerHTML = "☀️ Light Mode";
    }
    else{
        themeBtn.innerHTML = "🌙 Dark Mode";
    }

});

</script>

</body>
</html>